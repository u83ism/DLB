---
// グローバルナビゲーション
// currentPathを受け取り、アクティブなリンクをハイライトする
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// ベースURLを取得する（trailingSlash: 'always' により末尾スラッシュあり）
const base = import.meta.env.BASE_URL;

// ナビゲーションリンクの定義（external: true の場合は別タブで開く）
const navLinks = [
  { href: base, label: 'HOME' },
  { href: `${base}profile/`, label: 'プロフィール' },
  { href: `${base}br/`, label: 'バトルロワイアル' },
  { href: `${base}orphen/`, label: '魔術士オーフェン' },
  { href: `${base}o-yabu/`, label: '大藪春彦作品' },
  { href: `${base}history/`, label: 'サイトの歴史' },
  { href: 'https://u83-portal.web.app/', label: '🔗 ゆうやみポータル', external: true },
];

// パスが一致するかどうかを判定する
const isActive = (href: string): boolean => {
  if (href === base) return currentPath === base || currentPath === base.slice(0, -1);
  return currentPath.startsWith(href);
};
---

<details class="nav-details">
  <summary class="nav-summary">メニュー</summary>
  <nav aria-label="グローバルナビゲーション">
    {navLinks.map(({ href, label, external }) => (
      external
        ? <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>
        : <a href={href} class={isActive(href) ? 'active' : undefined} aria-current={isActive(href) ? 'page' : undefined}>{label}</a>
    ))}
  </nav>
</details>

<style>
  /* ===== デスクトップ: summary非表示・navを常時表示 ===== */
  @media (min-width: 601px) {
    .nav-summary {
      display: none;
    }

    /* UA stylesheetによるdetails内非表示を上書き */
    .nav-details > nav {
      display: flex;
    }
  }

  /* ===== 共通ナビスタイル ===== */
  nav {
    background: var(--white);
    border-bottom: 2px solid var(--mint);
    padding: 0 40px;
    display: flex;
    gap: 0;
    overflow-x: auto;
  }

  nav a {
    display: block;
    color: var(--text-muted);
    text-decoration: none;
    padding: 12px 18px;
    font-size: 0.83rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
  }

  nav a:hover {
    color: var(--mint-deep);
    border-bottom-color: var(--mint);
  }

  nav a.active {
    color: var(--mint-deep);
    border-bottom-color: var(--mint-deep);
    font-weight: 700;
  }

  /* ===== モバイル: detailsトグル ===== */
  @media (max-width: 600px) {
    .nav-details {
      background: var(--white);
      border-bottom: 2px solid var(--mint);
    }

    .nav-summary {
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 11px 16px;
      font-size: 0.83rem;
      font-weight: 700;
      color: var(--mint-deep);
      cursor: pointer;
      user-select: none;
    }

    .nav-summary::-webkit-details-marker {
      display: none;
    }

    .nav-summary::after {
      content: '▾';
      font-size: 1.8rem;
      line-height: 1;
    }

    .nav-details[open] .nav-summary::after {
      content: '▴';
    }

    nav {
      flex-direction: column;
      border-bottom: none;
      padding: 0;
      overflow-x: visible;
    }

    nav a {
      padding: 11px 16px;
      font-size: 0.83rem;
      border-bottom: none;
      border-top: 1px solid var(--border);
      margin-bottom: 0;
    }
  }
</style>
