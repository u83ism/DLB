---
// 共通レイアウト
import Header from '@/components/Header.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'よろず系個人サイト。バトルロワイアル・魔術士オーフェン・大藪春彦作品などを扱っています。' } = Astro.props;

// 現在のパスを取得する
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Don't Look Back</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} type="image/vnd.microsoft.icon" />
  </head>
  <style>
    /* ===== サイドバーなし（デフォルト） ===== */
    .page-body > div {
      /* コンテンツ列はページごとに .container で幅を制御する */
    }

    /* ===== サイドバーあり: PCのみグリッド ===== */
    .page-body.has-sidebar {
      display: grid;
      grid-template-columns: 260px 1fr;
      align-items: start;
    }

    .page-sidebar {
      position: sticky;
      top: 0;
      max-height: 100dvh;
      overflow-y: auto;
      padding: 44px 16px 44px 24px;
    }

    /* 900px以下ではグリッド解除・サイドバーを横スクロール帯として表示 */
    @media (max-width: 900px) {
      .page-body.has-sidebar {
        display: block;
      }

      .page-sidebar {
        position: static;
        max-height: none;
        overflow-y: visible;
        padding: 20px 24px;
        border-bottom: 1px solid var(--border);
      }
    }
  </style>
  <body>
    <Header />
    <Nav currentPath={currentPath} />
    <!-- サイドバースロットがある場合はグリッドレイアウトに切り替える -->
    <div class:list={['page-body', { 'has-sidebar': Astro.slots.has('sidebar') }]}>
      {Astro.slots.has('sidebar') && (
        <aside class="page-sidebar">
          <slot name="sidebar" />
        </aside>
      )}
      <div>
        <slot />
      </div>
    </div>
    <Footer />
  </body>
</html>
