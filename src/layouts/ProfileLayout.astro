---
// プロフィールページ専用レイアウト
// Markdownページのフロントマターを受け取ってプロフィールテーブルを描画する
import Layout from './Layout.astro';

interface Contact {
  readonly x?: string;
  readonly email?: string;
}

interface ProfileFrontmatter {
  readonly title: string;
  readonly description?: string;
  readonly note?: string;
  readonly handle: string;
  readonly gender: string;
  readonly location: string;
  readonly hobbies: string;
  readonly contact: Contact;
}

interface Props {
  readonly frontmatter: ProfileFrontmatter;
}

const { frontmatter: fm } = Astro.props;
---

<Layout title={fm.title} description={fm.description}>
  <div class="container">
    <main>
      <h1 class="page-title">{fm.title}</h1>

      {fm.note && <p class="note">※{fm.note}</p>}

      <dl class="profile-list">
        <div class="profile-item">
          <dt>ハンドル</dt>
          <dd>{fm.handle}</dd>
        </div>
        <div class="profile-item">
          <dt>性別</dt>
          <dd>{fm.gender}</dd>
        </div>
        <div class="profile-item">
          <dt>出身地/在住地</dt>
          <dd>{fm.location}</dd>
        </div>
        <div class="profile-item">
          <dt>趣味</dt>
          <dd>{fm.hobbies}</dd>
        </div>
        <div class="profile-item">
          <dt>連絡先</dt>
          <dd>
            {fm.contact.x && (
              <span>X: <a href={fm.contact.x} target="_blank" rel="noopener noreferrer">@{fm.contact.x.split('/').at(-1)}</a><br /></span>
            )}
            {fm.contact.email && (
              <span>メール: <a href={`mailto:${fm.contact.email}`}>{fm.contact.email}</a></span>
            )}
          </dd>
        </div>
      </dl>

      <!-- Markdownの本文（好きなライター等の複雑なセクション）を描画する -->
      <div class="prose">
        <slot />
      </div>
    </main>
  </div>
</Layout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 44px 24px;
  }

  @media (max-width: 600px) {
    .container {
      padding: 24px 16px;
    }
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 900;
    margin-bottom: 32px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--peach);
    color: var(--text);
  }

  .note {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  /* プロフィールリスト（テーブル風グリッドレイアウト） */
  .profile-list {
    font-size: 0.9rem;
    margin: 0 0 40px;
  }

  .profile-item {
    display: grid;
    grid-template-columns: 22% 1fr;
    border-bottom: 1px solid var(--border);
    line-height: 1.7;
  }

  .profile-item:first-child {
    border-top: 1px solid var(--border);
  }

  .profile-item dt {
    padding: 12px 16px;
    font-weight: 700;
    color: var(--peach-deep);
    background: var(--peach);
    text-align: right;
    display: block;
  }

  .profile-item dd {
    padding: 12px 16px;
    margin: 0;
    color: var(--text);
  }

  .profile-item dd a {
    color: var(--peach-deep);
  }

  @media (max-width: 500px) {
    .profile-item {
      grid-template-columns: 1fr;
    }

    .profile-item dt {
      text-align: left;
      border-bottom: none;
    }
  }

  /* Markdownの本文スタイル */
  .prose {
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--text);
  }

  .prose h2 {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 16px;
    margin-top: 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .prose h2::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .prose p {
    margin-bottom: 8px;
    color: var(--text-muted);
  }

  .prose strong {
    color: var(--text);
    font-weight: 700;
  }
</style>
