---
// 大藪春彦 生還者追跡ページ（主人公の生死調査）
import Layout from '@/layouts/Layout.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import { survived, dead, unknown } from '@/data/o-yabu-survivor';

const base = import.meta.env.BASE_URL;

// サイドメニュー用の見出し
const tocHeadings = [
  { slug: 'survive', text: `生存（${survived.length}人）` },
  { slug: 'dead', text: `死亡（${dead.length}人）` },
  { slug: 'unknown', text: `不明（${unknown.length}人）` },
];
---

<Layout title="生還者を探せ！（大藪春彦）" description="大藪春彦作品の主人公が最後まで生き残ったかどうか追跡。生存10・死亡17・不明4。">
  <TableOfContents slot="sidebar" headings={tocHeadings} />
  <div class="container">
    <nav class="breadcrumb" aria-label="パンくず">
      <a href={base}>HOME</a>
      <span aria-hidden="true">›</span>
      <a href={`${base}o-yabu/`}>大藪春彦</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">生還者を探せ！</span>
    </nav>

    <main>
      <h1 class="page-title">生還者を探せ！</h1>

      <section class="intro-section">
        <p>
          大薮作品の主人公は、世間一般でいう悪人にあたります。そして悪人の運命とも言うべきか、話の最後で死んでしまうケースが結構あります。しかし完遂し、見事に国外に脱出したりなど、生き残ったケースもあります。また明確には死ぬ描写が無く、生死不明なまま終わってしまう作品もあります。
        </p>
        <p>
          このコーナーでは「主人公が最後まで生き残ったかどうか」という点について調査していきたいと思います。なお、シリーズモノはシリーズ中の最後の本にて判断しております。短編集は、主人公一人ずつカウントします。
        </p>
        <dl class="criteria">
          <dt class="survive">生存</dt>
          <dd>物語終了時に生存し、その後の死を暗示されていないこと。</dd>
          <dt class="dead">死亡</dt>
          <dd>物語終了時に死亡していること。</dd>
          <dt class="unknown">不明</dt>
          <dd>物語終了時に生存しているが、その後の死が暗示されていること。</dd>
        </dl>
        <p class="summary">
          <strong class="survive">10人生存（32.3％）</strong>・
          <strong class="dead">17人死亡（54.8％）</strong>・
          <strong class="unknown">4人不明（12.9％）</strong>
          ／31人中
        </p>
      </section>

      <section id="survive">
        <h2 class="section-heading survive-heading">生存（{survived.length}人）</h2>
        <table class="survivor-table">
          <thead>
            <tr>
              <th class="col-work">作品名</th>
              <th class="col-hero">主人公名</th>
              <th>経緯</th>
            </tr>
          </thead>
          <tbody>
            {survived.map((e) => (
              <tr>
                <td class="col-work">{e.work}</td>
                <td class="col-hero">{e.hero}</td>
                <td>{e.detail}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section id="dead">
        <h2 class="section-heading dead-heading">死亡（{dead.length}人）</h2>
        <table class="survivor-table">
          <thead>
            <tr>
              <th class="col-work">作品名</th>
              <th class="col-hero">主人公名</th>
              <th>経緯</th>
            </tr>
          </thead>
          <tbody>
            {dead.map((e) => (
              <tr>
                <td class="col-work">{e.work}</td>
                <td class="col-hero">{e.hero}</td>
                <td>{e.detail}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section id="unknown">
        <h2 class="section-heading unknown-heading">不明（{unknown.length}人）</h2>
        <table class="survivor-table">
          <thead>
            <tr>
              <th class="col-work">作品名</th>
              <th class="col-hero">主人公名</th>
              <th>経緯</th>
            </tr>
          </thead>
          <tbody>
            {unknown.map((e) => (
              <tr>
                <td class="col-work">{e.work}</td>
                <td class="col-hero">{e.hero}</td>
                <td>{e.detail}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    </main>
  </div>
</Layout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 44px 24px;
  }

  @media (max-width: 600px) {
    .container {
      padding: 24px 16px;
    }
  }

  .breadcrumb {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--lavender-deep);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 900;
    margin-bottom: 32px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--lavender);
    color: var(--text);
  }

  /* イントロ */
  .intro-section {
    margin-bottom: 32px;
  }

  .intro-section p {
    font-size: 0.9rem;
    line-height: 1.8;
    margin-bottom: 12px;
  }

  .criteria {
    font-size: 0.88rem;
    line-height: 1.8;
    margin: 16px 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4px 16px;
    align-items: baseline;
  }

  .criteria dt {
    font-weight: 700;
    white-space: nowrap;
  }

  .criteria dd {
    margin: 0;
  }

  .summary {
    font-size: 0.9rem;
    padding: 12px 16px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-top: 16px;
  }

  /* 生死カラー */
  .survive { color: #1a6fb5; }
  .dead { color: #c0392b; }
  .unknown { color: #1e8449; }

  /* セクション */
  section + section {
    margin-top: 48px;
  }

  .section-heading {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 16px;
    padding: 8px 0 8px 16px;
  }

  .survive-heading {
    border-left: 4px solid #1a6fb5;
    color: #1a6fb5;
  }

  .dead-heading {
    border-left: 4px solid #c0392b;
    color: #c0392b;
  }

  .unknown-heading {
    border-left: 4px solid #1e8449;
    color: #1e8449;
  }

  /* テーブル（データ用途のため<table>を維持） */
  .survivor-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  .survivor-table th,
  .survivor-table td {
    padding: 10px 12px;
    border: 1px solid var(--border);
    vertical-align: top;
    line-height: 1.7;
  }

  .survivor-table thead th {
    background: var(--lavender);
    color: var(--lavender-deep);
    font-weight: 700;
    white-space: nowrap;
  }

  .survivor-table tbody tr:nth-child(even) td {
    background: color-mix(in srgb, var(--lavender) 15%, var(--white));
  }

  .col-work {
    width: 22%;
    white-space: nowrap;
    font-weight: 600;
  }

  .col-hero {
    width: 15%;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .survivor-table {
      display: block;
      overflow-x: auto;
    }

    .col-work {
      white-space: normal;
    }
  }
</style>
