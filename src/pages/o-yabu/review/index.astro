---
// 大藪春彦 作品レビューページ（S〜Eランク）
import Layout from '@/layouts/Layout.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import { ranks } from '@/data/o-yabu-reviews';

const base = import.meta.env.BASE_URL;

---

<Layout title="大藪春彦 作品レビュー" description="大藪春彦作品のS〜Eランク個人レビュー一覧。">
  <TableOfContents slot="sidebar" headings={ranks.map(r => ({ slug: r.rank, text: r.label }))} />
  <div class="container">
    <nav class="breadcrumb" aria-label="パンくず">
      <a href={base}>HOME</a>
      <span aria-hidden="true">›</span>
      <a href={`${base}o-yabu/`}>大藪春彦</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">作品レビュー</span>
    </nav>

    <main>
      <h1 class="page-title">作品レビュー</h1>

      <p class="intro">
        大薮春彦氏の著作は約120タイトルにものぼります。流石に多いので全部は無理ですが、読んだやつをどんどんレビューしていきます。ランクに関しては、やはり賛否両論分かれると思いますが、あくまでも私的な意見なので……文句等は勘弁して下さい。
      </p>

      {ranks.map((r) => (
        <section class="rank-section" id={r.rank}>
          <h2 class={`rank-heading ${r.color}`}>{r.label}</h2>
          <div class="entry-list">
            {r.entries.map((e) => (
              <article class="entry" id={e.id}>
                <div class="entry-title">
                  {e.series && <span class="entry-series">{e.series}</span>}
                  <strong>{e.title}</strong>
                </div>
                <p class={`entry-body${e.pending ? ' pending' : ''}`}>{e.body}</p>
              </article>
            ))}
          </div>
        </section>
      ))}
    </main>
  </div>
</Layout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 44px 24px;
  }

  @media (max-width: 600px) {
    .container {
      padding: 24px 16px;
    }
  }

  .breadcrumb {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--lavender-deep);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 900;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--lavender);
    color: var(--text);
  }

  .intro {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 28px;
  }

  /* ランクセクション */
  .rank-section {
    margin-bottom: 48px;
  }

  .rank-heading {
    font-size: 1.1rem;
    font-weight: 900;
    padding: 8px 16px;
    border-radius: 6px;
    margin-bottom: 16px;
  }

  /* ランクカラー定義 */
  .rank-s {
    background: #fff3cd;
    color: #b8860b;
    border-color: #b8860b;
  }

  .rank-a {
    background: #d4edda;
    color: #155724;
    border-color: #155724;
  }

  .rank-b {
    background: #cce5ff;
    color: #004085;
    border-color: #004085;
  }

  .rank-c {
    background: #f8d7da;
    color: #721c24;
    border-color: #721c24;
  }

  .rank-d {
    background: #ffe5cc;
    color: #7c4a00;
    border-color: #7c4a00;
  }

  .rank-e {
    background: #e9ecef;
    color: #495057;
    border-color: #6c757d;
  }

  /* エントリーリスト */
  .entry-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .entry {
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }

  .entry:last-child {
    border-bottom: none;
  }

  .entry-title {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 8px;
  }

  .entry-series {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .entry-title strong {
    font-size: 0.95rem;
    color: var(--text);
  }

  .entry-body {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--text);
    margin: 0;
  }

  .entry-body.pending {
    color: var(--text-muted);
    font-style: italic;
  }
</style>
