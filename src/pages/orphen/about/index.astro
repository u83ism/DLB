---
// 魔術士オーフェン 概要ページ（小説シリーズ）
import Layout from '@/layouts/Layout.astro';

// 既刊リストのデータ定義
type Volume = { readonly vol: string; readonly title: string; };

const hagure: readonly Volume[] = [
  { vol: '1巻', title: '我が呼び声に応えよ獣' },
  { vol: '2巻', title: '我が命にしたがえ機械' },
  { vol: '3巻', title: '我が胸で眠れ亡霊' },
  { vol: '4巻', title: '我が森に集え狼' },
  { vol: '5巻', title: '我が過去を消せ暗殺者' },
  { vol: '6巻', title: '我が搭に来たれ後継者' },
  { vol: '7巻', title: '我が遺志を伝えよ魔王' },
  { vol: '8巻', title: '我が聖都を濡らせ血涙' },
  { vol: '9巻', title: '我が神に弓ひけ背約者（上）' },
  { vol: '10巻', title: '我が神に弓ひけ背約者（下）' },
  { vol: '11巻', title: '我が夢に沈め楽園（上）' },
  { vol: '12巻', title: '我が夢に沈め楽園（下）' },
  { vol: '13巻', title: '我が運命導け魔剣' },
  { vol: '14巻', title: '我が心求めよ悪魔' },
  { vol: '15巻', title: '我が絶望つつめ緑' },
  { vol: '16巻', title: '我が戦場に踊れ来訪者' },
  { vol: '17巻', title: '我が庭に響け銃声' },
  { vol: '18巻', title: '我が館にさまよえ虚像' },
  { vol: '19巻', title: '我が聖域に開け扉（上）' },
  { vol: '20巻', title: '我が聖域に開け扉（下）' },
];

const mubou: readonly Volume[] = [
  { vol: '1巻', title: 'てめぇら、とっとと金返せ！' },
  { vol: '2巻', title: '馬鹿は一人でたくさんだ！' },
  { vol: '3巻', title: 'お前はいったいなんなんだ！？' },
  { vol: '4巻', title: '顔を洗って出直しな！' },
  { vol: '5巻', title: 'あきれてものも言えねえぜ！' },
  { vol: '6巻', title: '自分がイヤにならねえか？' },
  { vol: '7巻', title: '一生ひとりで遊んでろ！' },
  { vol: '8巻', title: 'それはいろいろまずいだろ？' },
  { vol: '9巻', title: '同情なんていらねえぜ！' },
  { vol: '10巻', title: 'なかったことに出来ねえか？' },
  { vol: '11巻', title: 'もういいかげんあきらめろ！' },
  { vol: '12巻', title: 'そのまま穴でも掘っていろ！' },
  { vol: '13巻', title: 'これで終わりと思うなよ！' },
];

const mawari: readonly Volume[] = [
  { vol: '1巻', title: '悪逆の森' },
  { vol: '2巻', title: 'ゼロの交点' },
];
---

<Layout title="魔術士オーフェン 概要" description="魔術士オーフェン小説シリーズの概要と既刊リスト。">
  <div class="container">
    <nav class="breadcrumb" aria-label="パンくず">
      <a href="/DLB/">HOME</a>
      <span aria-hidden="true">›</span>
      <a href="/DLB/orphen/">魔術士オーフェン</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">概要</span>
    </nav>

    <main>
      <h1 class="page-title">魔術士オーフェン 概要</h1>

      <section class="section">
        <h2 class="section-heading">はじめに</h2>
        <p>
          魔術士オーフェンとは、富士見書房より発売されている青少年向けファンタジー小説です。はぐれ旅編20巻・無謀編13巻が発売されています。シリーズは「はぐれ旅」と「無謀編」と「まわり道」に分かれています。
        </p>
        <p>
          「はぐれ旅」は俗に本編と呼ばれる方で、主人公オーフェンが行方不明になった姉アザリーを追って世界中を巡る旅の話です。20巻にも及ぶ大長編ですが、2003年9月発売の「我が聖域に開け扉（下）」で完結しました。
        </p>
        <p>
          「無謀編」はいわゆる番外編で、オーフェンが"牙の塔"を出奔してから流れ着いた街・トトカンタでの生活をギャグ調で描いたものです。ドラゴンマガジンでの連載が2000年に終了して、単行本の発売も2003年10月発売「これで終わりと思うなよ！」で完結しました。また無謀編の単行本には書き下ろしで、オーフェンが牙の搭にいた頃の話（プレ・オーフェン）も掲載されています。
        </p>
        <p>
          「まわり道」は、角川ミニ文庫という超ミニサイズの文庫部門から発売されました。「はぐれ旅」の途中でのショートストーリーを描いています。ただし角川ミニ文庫そのものが廃止になったので、入手は多少難しいかと思われます。他にも漫画版・アニメ版・ゲームなど多数のメディアで展開されました。
        </p>
        <p>
          世界観は最初は中世ヨーロッパを意識してたらしいのですが、シリーズが続くにつれて、イギリスの産業革命の頃を意識して書かれるようになったそうです。この世界には「魔術」と呼ばれる力があり、魔術士と呼ばれる者だけがその力を行使できます。
        </p>
        <p>
          タイトルの魔術士「オーフェン」とは主人公の「オーフェン」の事です。タイトル通り魔術士で、現在は身分を隠しているものの、黒魔術士の育成施設の最高峰"牙の搭"で、幼少の頃より育てられました。オーフェンというのは実は伝説になりかけた暗殺者、"サクセサー・オブ・レザーエッジ（鋼の後継）"という通り名を持つ、"キリランシェロ・フィンランディ"の偽名です。
        </p>
      </section>

      <section class="section">
        <h2 class="section-heading">既刊リスト</h2>

        <div class="book-list">
          <div class="series">
            <h3 class="series-title">はぐれ旅</h3>
            <table class="volume-table">
              <tbody>
                {hagure.map((v) => (
                  <tr>
                    <td class="vol-num">{v.vol}</td>
                    <td>{v.title}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="series">
            <h3 class="series-title">無謀編</h3>
            <table class="volume-table">
              <tbody>
                {mubou.map((v) => (
                  <tr>
                    <td class="vol-num">{v.vol}</td>
                    <td>{v.title}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="series">
            <h3 class="series-title">まわり道</h3>
            <table class="volume-table">
              <tbody>
                {mawari.map((v) => (
                  <tr>
                    <td class="vol-num">{v.vol}</td>
                    <td>{v.title}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 44px 24px;
  }

  @media (max-width: 600px) {
    .container {
      padding: 24px 16px;
    }
  }

  .breadcrumb {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--sky-deep);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 900;
    margin-bottom: 32px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--sky);
    color: var(--text);
  }

  .section {
    margin-bottom: 48px;
  }

  .section-heading {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 16px;
    padding: 8px 0 8px 16px;
    border-left: 4px solid var(--sky-deep);
  }

  .section p {
    font-size: 0.92rem;
    line-height: 1.8;
    margin-bottom: 14px;
  }

  /* 既刊リスト */
  .book-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .series-title {
    font-size: 0.9rem;
    font-weight: 800;
    background: var(--sky);
    color: var(--sky-deep);
    padding: 8px 14px;
    border-radius: 6px 6px 0 0;
    margin-bottom: 0;
  }

  .volume-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  .volume-table td {
    padding: 8px 14px;
    border: 1px solid var(--border);
  }

  .volume-table tr:nth-child(even) td {
    background: color-mix(in srgb, var(--sky) 10%, var(--white));
  }

  .vol-num {
    white-space: nowrap;
    width: 80px;
    font-weight: 700;
    color: var(--sky-deep);
  }
</style>
