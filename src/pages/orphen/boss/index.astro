---
// 魔術士オーフェン PS2 ボス攻略ページ
import Layout from '@/layouts/Layout.astro';

// 属性防御の数値を評価テキストに変換（1=最強, 5=最弱）
const ratingLabel = (n: number): string => {
  const labels = ['', '最強', '強', '普通', '弱', '最弱'] as const;
  return labels[n] ?? String(n);
};

// ボスデータの型定義
type Defense = {
  readonly 物理: number;
  readonly 絶対: number;
  readonly 暗黒: number;
  readonly 風: number;
  readonly 火炎: number;
  readonly 光電: number;
};

type BossEntry = {
  readonly id: string;
  readonly name: string;
  readonly chapter: string;
  readonly enemies: ReadonlyArray<{
    readonly name: string;
    readonly hp: number;
    readonly def: number;
    readonly attr: string;
    readonly defense: Defense;
    readonly attacks: string;
  }>;
  readonly guide: string;
};

const bosses: readonly BossEntry[] = [
  {
    id: 'ingeldo',
    name: 'インゲルド＆カージック',
    chapter: '序章',
    enemies: [
      {
        name: 'インゲルド',
        hp: 120, def: 0, attr: '暗黒属性',
        defense: { 物理: 1, 絶対: 1, 暗黒: 1, 風: 1, 火炎: 2, 光電: 2 },
        attacks: '体当たり（攻撃力：6）・泡噴き（混乱効果/攻撃力：3）・樽投げ（火炎属性/攻撃力：4）',
      },
      {
        name: 'カージック',
        hp: 10, def: 0, attr: '光電属性',
        defense: { 物理: 5, 絶対: 2, 暗黒: 1, 風: 2, 火炎: 4, 光電: 4 },
        attacks: '体当たり（攻撃力：1）',
      },
    ],
    guide: 'ゲームをスタートした直後に現れるボス。最初なんで戦いにくいかもしれませんが、しっかりと防御しつつ隙を見て「光の白刃」でも炸裂させてやればそう苦労することはないかと。インゲルド戦の後にわらわら出てくるカージックはこれまた「光の白刃」で一掃しちゃってください。',
  },
  {
    id: 'gariga',
    name: 'ギャリガ',
    chapter: 'セフィ編・ゼイアス編・マー編（計3回）',
    enemies: [
      {
        name: 'ギャリガ',
        hp: 66, def: 0, attr: '光電属性',
        defense: { 物理: 2, 絶対: 3, 暗黒: 4, 風: 4, 火炎: 3, 光電: 1 },
        attacks: '雷レーザー（攻撃力：3/6/8）・雷弾攻撃（光電属性/攻撃力：7/13/19）',
      },
    ],
    guide: '各エピソードの最初に戦うので計3回も戦うハメになるボス。回数を経るごとに攻撃力が高くなり、3回目では攻撃力も最高クラスだが、あまりにも攻撃パターンが分かりやすすぎるので、後半ではまず食らうことは無いと思います。適当に暗黒・風属性魔術で倒してください。一応、ある程度時間が経つとオーフェンのいるマスト自体を潰す攻撃（ゲームオーバー確定）をしてくるので、実質的にタイムリミットがあります。',
  },
  {
    id: 'kebur',
    name: 'ケブール',
    chapter: 'セフィ編',
    enemies: [
      {
        name: 'ケブール',
        hp: 108, def: 0, attr: '火炎属性',
        defense: { 物理: 1, 絶対: 4, 暗黒: 4, 風: 2, 火炎: 1, 光電: 2 },
        attacks: '体当たり（攻撃力：0）・パンチ（攻撃力：0）・パワーウェイブ（火炎属性/攻撃力：5）',
      },
    ],
    guide: '特殊ルール下での戦闘になります。敵のタックルを食らうと後ろに吹っ飛び、10回ほど食らうと穴に叩き落とされゲームオーバー。対抗できるのは「降魔の剣」。向こうからタックルを仕掛けてくるのにカウンターで叩き切ることと、振りかぶり攻撃のモーションが遅いので割り込むように連続攻撃を叩きこむ方法の2種類が攻撃チャンスです。',
  },
  {
    id: 'gornas',
    name: 'ゴルナス',
    chapter: 'セフィ編（最終ボス）',
    enemies: [
      {
        name: 'ゴルナス',
        hp: 120, def: 0, attr: '風属性',
        defense: { 物理: 1, 絶対: 2, 暗黒: 1, 風: 1, 火炎: 1, 光電: 2 },
        attacks: '体当たり（攻撃力：1）・レーザー（攻撃力：1）',
      },
    ],
    guide: 'セフィ編最終ボスですが、攻撃パターンが分かりやすい上に攻撃力も低いので特に苦労もなく倒せると思います。絶対系バリアを貼ってる関係上、「光の白刃」で攻め立てるのがお薦めです。',
  },
  {
    id: 'zigios',
    name: 'ジーギオス＆ザンドル',
    chapter: 'ゼイアス編',
    enemies: [
      {
        name: 'ジーギオスの管',
        hp: 120, def: 0, attr: '無属性',
        defense: { 物理: 0, 絶対: 3, 暗黒: 3, 風: 3, 火炎: 3, 光電: 3 },
        attacks: 'なし',
      },
      {
        name: 'ジーギオス',
        hp: 10, def: 0, attr: '無属性',
        defense: { 物理: 3, 絶対: 1, 暗黒: 2, 風: 4, 火炎: 4, 光電: 2 },
        attacks: '体当たり（攻撃力：1）',
      },
      {
        name: 'ザンドル',
        hp: 115, def: 0, attr: '光電属性',
        defense: { 物理: 1, 絶対: 1, 暗黒: 1, 風: 1, 火炎: 1, 光電: 1 },
        attacks: '糸吐き（攻撃力：3）・レーザー（攻撃力：2）・光電球（光電属性/攻撃力：5）',
      },
      {
        name: 'ザンドルの糸',
        hp: 40, def: 0, attr: '火炎属性',
        defense: { 物理: 5, 絶対: 1, 暗黒: 2, 風: 1, 火炎: 0, 光電: 2 },
        attacks: 'なし',
      },
    ],
    guide: '立て続けの2連戦。最初のジーギオス戦は管に直撃系魔術連射、ジーギオスが大量に出てきたら溜めて一掃。続くザンドル戦は「降魔の剣」一択。蜘蛛の巣バリアを連続攻撃で破り、少々溜めてから本体を連続攻撃。',
  },
  {
    id: 'begamu',
    name: 'ベガーム',
    chapter: 'ゼイアス編',
    enemies: [
      {
        name: 'ベガーム',
        hp: 108, def: 10, attr: '暗黒属性',
        defense: { 物理: 2, 絶対: 2, 暗黒: 1, 風: 2, 火炎: 4, 光電: 4 },
        attacks: '暗黒魔術弾（暗黒属性/攻撃力10）・特殊反射魔術（攻撃力：7）',
      },
    ],
    guide: 'オーフェンに変身している時は攻撃すると自分にダメージが跳ね返ります。「光輪の鎧」を使って、暗黒魔術弾を跳ね返すのが正統な倒し方。強引にいくなら、擬態解除→弾系魔術の間に弾系魔術を撃つと敵にダメージを与えることも可能です。',
  },
  {
    id: 'zeltron',
    name: 'ゼルトロン',
    chapter: 'ゼイアス編（最終ボス）',
    enemies: [
      {
        name: 'ゼルトロン',
        hp: 120, def: 0, attr: '風属性',
        defense: { 物理: 1, 絶対: 1, 暗黒: 1, 風: 1, 火炎: 1, 光電: 1 },
        attacks: '足攻撃（攻撃力：5）・風の砲（風属性/攻撃力：3）・隕石攻撃（攻撃力：7）',
      },
    ],
    guide: 'ゼイアス編ラスボス。攻撃力が高く属性防御やHPも多いです。是非装備しておきたい魔術は「降魔の剣（赤）」。まずは左奥の爪状の足を攻撃しましょう。そうすると手前の殻が開くのでそこを集中攻撃してください。',
  },
  {
    id: 'zofemu',
    name: 'ゾフェーム',
    chapter: 'マー編',
    enemies: [
      {
        name: 'ゾフェーム',
        hp: 96, def: 0, attr: '風属性',
        defense: { 物理: 2, 絶対: 4, 暗黒: 2, 風: 1, 火炎: 2, 光電: 4 },
        attacks: '風の弾（集中）（風属性/攻撃力：3）・風の弾（拡散）（風属性/攻撃力：1）',
      },
    ],
    guide: 'ゾフェームは攻撃パターンも分かりやすく攻撃力もそれほど高くないのでやられることはまずありません。……がとにかく時間がかかります。オーフェンの周りを周回して攻撃してくる。どこに出てくるかさっぱり分からず、ほとんど運試し。目の前に降りてきた時が攻撃チャンスです。根気強く戦いましょう。',
  },
  {
    id: 'burisugar',
    name: 'ブリスガー',
    chapter: 'マー編（中ボス）',
    enemies: [
      {
        name: 'ブリスガー',
        hp: 120, def: 5, attr: '絶対属性',
        defense: { 物理: 2, 絶対: 2, 暗黒: 3, 風: 4, 火炎: 4, 光電: 3 },
        attacks: '巻き付き（攻撃力：5）・絶対魔術弾（絶対属性/攻撃力：4）',
      },
    ],
    guide: 'アイジストを生み出してうざいので、「降魔の剣（赤）」でさっさと切り伏せましょう。無いなら火炎や風属性で攻撃してください。大した苦労もなく倒せると思います。',
  },
  {
    id: 'biogure',
    name: 'ビオグレイ',
    chapter: 'マー編（最終ボス）',
    enemies: [
      {
        name: 'ビオグレイ',
        hp: 60, def: 0, attr: '暗黒属性',
        defense: { 物理: 2, 絶対: 1, 暗黒: 1, 風: 1, 火炎: 2, 光電: 2 },
        attacks: '物理攻撃（攻撃力：2）・たたく（攻撃力：4）・はさむ（攻撃力：5）・バラバラ（攻撃力：2）・暗黒レーザー（暗黒属性/攻撃力：2）',
      },
    ],
    guide: 'マー編ラスボス。しばらく戦って、マーが笛を吹くまではダメージが入りません。トリッキーな攻撃が特徴ですが、攻撃パターンを把握すればそれほど苦労しないと思います。HPも低いですが、属性防御が強いので火炎か光電属性魔法で攻撃するのがベター。',
  },
  {
    id: 'bossrush',
    name: 'ボスラッシュ',
    chapter: '最終章',
    enemies: [],
    guide: '最終章は今までのボス6連戦（ケブール→ゴルナス→ザンドル→ゼルトロン→ゾフェーム→ビオグレイ）からスタートします。大変ですが今まで倒したことがあるはずなので、頑張ってください。ヤバくなったら「戦闘をやり直す」コマンドを忘れずに（その戦闘の最初からスタート）。ちなみにビオグレイは最初からダメージを与えれるようになっています。',
  },
  {
    id: 'gaia',
    name: 'ガイア',
    chapter: '最終章（ラスボス）',
    enemies: [
      {
        name: 'ガイア',
        hp: 236, def: 0, attr: '無属性',
        defense: { 物理: 2, 絶対: 2, 暗黒: 2, 風: 2, 火炎: 2, 光電: 2 },
        attacks: 'たたく（攻撃力：5）・光線（攻撃力：3）・粒子砲（攻撃力：7）',
      },
      {
        name: 'ビット',
        hp: 30, def: 0, attr: '無属性',
        defense: { 物理: 2, 絶対: 2, 暗黒: 2, 風: 2, 火炎: 2, 光電: 2 },
        attacks: 'ビーム（攻撃力：1）・体当たり（攻撃力：1）',
      },
    ],
    guide: '最終ボスにして最強最悪の難易度を誇る「ガイア」。負ければ最終章の最初（6連戦）からやり直しになるので「戦闘をやり直す」コマンドは絶対必須。腹部・右腕・左腕・頭の4パーツに分かれています。まず落とすべきは「左腕」——ガイアのどの部位に撃った魔術も完全防御してきます。攻撃タイミングは魔術をガードさせた後の戻り際。次に腹部（光線パーツ）、右腕の順で落としましょう。ビット攻撃はライフが減るごとに最大10機になり、強化済みの直撃魔術を最速発動させることのみで対処します。管理人の初クリア時は対ガイア戦だけで3時間かかりました……。',
  },
];
---

<Layout title="ボス攻略（オーフェン）" description="魔術士オーフェン PS2版 ボス攻略。各ボスのHP・属性・攻略法。">
  <div class="container">
    <nav class="breadcrumb" aria-label="パンくず">
      <a href="/DLB/">HOME</a>
      <span aria-hidden="true">›</span>
      <a href="/DLB/orphen/">魔術士オーフェン</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">ボス攻略</span>
    </nav>

    <main>
      <h1 class="page-title">ボス攻略</h1>

      <p class="intro">
        各種ボスについての攻略です。ボス攻略の基本は「クリスタル1個になったらスタートボタン→戦闘を最初からやり直す」。このゲームは回復アイテムは戦闘中使えませんが、やり直しで体力全快して再戦可能です。<br />
        <strong>属性防御の欄は1（最強）→5（最弱）。</strong>
      </p>

      <nav class="jump-nav" aria-label="ボス一覧">
        {bosses.map((b) => (
          <a href={`#${b.id}`}>{b.name}</a>
        ))}
      </nav>

      {bosses.map((boss) => (
        <section class="boss-section" id={boss.id}>
          <h2 class="boss-name">{boss.name}</h2>
          <p class="boss-chapter">{boss.chapter}</p>

          {boss.enemies.length > 0 && (
            <div class="enemy-tables">
              {boss.enemies.map((enemy) => (
                <table class="enemy-table">
                  <thead>
                    <tr><th colspan="2">{enemy.name}</th></tr>
                  </thead>
                  <tbody>
                    <tr>
                      <th>HP</th>
                      <td>{enemy.hp}</td>
                    </tr>
                    <tr>
                      <th>防御力</th>
                      <td>{enemy.def}</td>
                    </tr>
                    <tr>
                      <th>属性</th>
                      <td>{enemy.attr}</td>
                    </tr>
                    <tr>
                      <th>属性防御</th>
                      <td class="defense">
                        {(Object.entries(enemy.defense) as [string, number][]).map(([attr, val]) => (
                          <span class={`def-badge def-${val}`}>{attr}{val}</span>
                        ))}
                      </td>
                    </tr>
                    <tr>
                      <th>攻撃手段</th>
                      <td>{enemy.attacks}</td>
                    </tr>
                  </tbody>
                </table>
              ))}
            </div>
          )}

          <p class="guide">{boss.guide}</p>
        </section>
      ))}
    </main>
  </div>
</Layout>

<style>
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 44px 24px;
  }

  @media (max-width: 600px) {
    .container {
      padding: 24px 16px;
    }
  }

  .breadcrumb {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--sky-deep);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 900;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--sky);
    color: var(--text);
  }

  .intro {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 24px;
  }

  /* ジャンプナビ */
  .jump-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 40px;
    padding: 16px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .jump-nav a {
    font-size: 0.78rem;
    color: var(--sky-deep);
    text-decoration: none;
    padding: 3px 10px;
    background: var(--sky);
    border-radius: 99px;
    font-weight: 600;
    transition: background 0.1s;
  }

  .jump-nav a:hover {
    background: color-mix(in srgb, var(--sky) 60%, var(--sky-deep));
  }

  /* ボスセクション */
  .boss-section {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .boss-section:last-child {
    border-bottom: none;
  }

  .boss-name {
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--sky-deep);
    margin-bottom: 4px;
  }

  .boss-chapter {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  /* 敵データテーブル */
  .enemy-tables {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 16px;
  }

  .enemy-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.84rem;
  }

  .enemy-table thead tr {
    background: var(--sky);
  }

  .enemy-table thead th {
    padding: 8px 14px;
    color: var(--sky-deep);
    font-weight: 800;
    text-align: left;
    border: 1px solid var(--border);
  }

  .enemy-table tbody th {
    background: color-mix(in srgb, var(--sky) 20%, var(--white));
    padding: 7px 14px;
    font-weight: 700;
    color: var(--sky-deep);
    white-space: nowrap;
    width: 100px;
    border: 1px solid var(--border);
    text-align: right;
  }

  .enemy-table tbody td {
    padding: 7px 14px;
    border: 1px solid var(--border);
    line-height: 1.6;
  }

  /* 属性防御バッジ */
  .defense {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .def-badge {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 99px;
    background: var(--border);
    color: var(--text-muted);
  }

  /* 属性防御値によって色を変える */
  .def-1 { background: var(--mint); color: var(--mint-deep); }
  .def-2 { background: var(--sky); color: var(--sky-deep); }
  .def-3 { background: var(--border); color: var(--text-muted); }
  .def-4 { background: var(--peach); color: var(--peach-deep); }
  .def-5 { background: var(--lavender); color: var(--lavender-deep); }

  .guide {
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--text);
  }
</style>
