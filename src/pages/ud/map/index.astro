---
// UNLIMITED DARK マップページ（会場エリア図・禁止エリア発動タイミング）
import Layout from '@/layouts/Layout.astro';

// 禁止エリア発動タイミング表データ
const zones = [
  { stage: '第1段階', area: '公園エリア', trigger: '残り20人' },
  { stage: '第2段階', area: '学校エリア', trigger: '残り15人' },
  { stage: '第3段階', area: 'ショッピングセンターエリア', trigger: '残り10人' },
  { stage: '第4段階', area: '市民会館エリア', trigger: '残り5人' },
  { stage: '最終段階', area: '会場全域', trigger: '第4段階から6時間経過後' },
] as const;
---

<Layout title="マップ（UNLIMITED DARK）" description="UNLIMITED DARK の会場マップと禁止エリア発動タイミング。">
  <div class="container">
    <nav class="breadcrumb" aria-label="パンくず">
      <a href="/DLB/">HOME</a>
      <span aria-hidden="true">›</span>
      <a href="/DLB/br/">バトルロワイアル</a>
      <span aria-hidden="true">›</span>
      <a href="/DLB/ud/">UNLIMITED DARK</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">マップ</span>
    </nav>

    <main>
      <h1 class="page-title">会場マップ</h1>

      <div class="map-wrap">
        <img src="/DLB/ud/udmap.gif" alt="UNLIMITED DARK 会場マップ（500×500）" width="500" height="500" class="map-img" />
      </div>

      <section class="section">
        <h2 class="section-heading">禁止エリア発動タイミング</h2>
        <table class="zone-table">
          <thead>
            <tr>
              <th>段階</th>
              <th>対象エリア</th>
              <th>発動条件</th>
            </tr>
          </thead>
          <tbody>
            {zones.map((z) => (
              <tr>
                <td class="stage">{z.stage}</td>
                <td>{z.area}</td>
                <td>{z.trigger}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <nav class="back-nav">
        <a href="/DLB/ud/" class="back-btn">← UNLIMITED DARK TOP</a>
      </nav>
    </main>
  </div>
</Layout>

<style>
  .container { max-width: 800px; margin: 0 auto; padding: 44px 24px; }
  @media (max-width: 600px) { .container { padding: 24px 16px; } }
  .breadcrumb { font-size: 0.78rem; color: var(--text-muted); margin-bottom: 24px; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .breadcrumb a { color: var(--sky-deep); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .page-title { font-size: 1.6rem; font-weight: 900; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 3px solid var(--sky); color: var(--text); }
  .map-wrap { text-align: center; margin-bottom: 40px; }
  .map-img { max-width: 100%; height: auto; border: 1px solid var(--border); border-radius: var(--radius); }
  .section { margin-bottom: 40px; }
  .section-heading { font-size: 1rem; font-weight: 800; color: var(--text); margin-bottom: 16px; padding: 8px 0 8px 16px; border-left: 4px solid var(--sky-deep); }
  .zone-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
  .zone-table th { background: var(--sky); color: var(--sky-deep); font-weight: 700; padding: 10px 12px; border: 1px solid var(--border); text-align: left; }
  .zone-table td { padding: 10px 12px; border: 1px solid var(--border); }
  .zone-table tr:nth-child(even) td { background: var(--bg); }
  .stage { font-weight: 700; white-space: nowrap; }
  .back-nav { margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border); }
  .back-btn { display: inline-block; padding: 8px 16px; background: var(--white); border: 1px solid var(--sky-deep); border-radius: var(--radius); font-size: 0.84rem; font-weight: 600; color: var(--sky-deep); text-decoration: none; }
  .back-btn:hover { background: var(--sky); }
</style>
