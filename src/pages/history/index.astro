---
// サイトの歴史ページ
import Layout from '@/layouts/Layout.astro';

// サイト歴史データの定義
type HistoryEntry = {
  readonly period: string;
  readonly isHighlight: boolean;
  readonly meta?: {
    readonly siteName: string;
    readonly handle: string;
    readonly genres: string;
    readonly sub?: string;
  };
  readonly desc: string;
};

const historyEntries: readonly HistoryEntry[] = [
  {
    period: '〈第1期〉2000/1/1 ～ 2000/6/?',
    isHighlight: true,
    meta: {
      siteName: 'Game&Moncolle FanCity\'2000（GMFC）',
      handle: '荒野の旅人',
      genres: 'ワイルドアームズ、モンスターコレクションTCG、魔術士オーフェン（途中追加）',
    },
    desc: '前年の夏頃からちょびちょびと作ってきたサイトを、正月のおめでたムードに乗せられた父親に勧められて急に公開。取り扱いジャンル、最初はWAとモンコレでしたが、1ヶ月ほどして魔術士オーフェンが追加。サイト名とのギャップに悩む日が始まりました。ちなみにサイト名の「2000」は年ごとに数字が変わっていく予定でした。',
  },
  {
    period: '2000/6/? ～ 2000/9/?',
    isHighlight: false,
    desc: 'サイト名と取り扱いジャンルのギャップに耐え切れず休止→改装作業。かなり長い間改装していました……が、この後好調にコンテンツの作成が出来たので、自分としては結構この充電期間は良かったと思います。',
  },
  {
    period: '〈第2期〉2000/9/? ～ 2001/7/31',
    isHighlight: true,
    meta: {
      siteName: 'Eternal City ～Eden of Mirage～（ECEM）',
      handle: '荒野の旅人',
      genres: 'ワイルドアームズ、モンスターコレクションTCG、魔術士オーフェン、ガンガンヴァーサス（途中追加→削除）',
    },
    desc: 'サイト名を多ジャンル対応用に変更しつつリニューアル。始まったばかりのガンガンヴァーサスが途中で加わりましたが、いきなりのSPカード乱発で萎えて2ヶ月程で廃止。その中でも大変アクセス数を増やすことになったのが、末期に作った「ORPHEN Remix」・「BATTLE ROYALE ETERNAL」。',
  },
  {
    period: '2001/8/1 ～ 2002/3/31',
    isHighlight: false,
    desc: '高校受験につき休止。8ヶ月間とわりと長い間休みましたが、本館からの「ORPHEN Remix」へのリンクが効いたのか、謎なペースでアクセス数が伸びました。',
  },
  {
    period: '〈第3期〉2002/4/1 ～ 2004/3/31',
    isHighlight: true,
    meta: {
      siteName: 'Mirrorball Satellite（鏡球衛星）',
      handle: '夕闇幻楼',
      genres: 'ワイルドアームズ、魔術士オーフェン、バトルロワイアル、ラグナロクオンライン（途中追加→削除）他',
      sub: 'BRN（途中追加）→OBRN',
    },
    desc: '復活。サイト名＆ハンドル変更。受験中に読んで感動したバトルロワイアルが追加。2002年7月に下位サイト「BRN（現OBRN）」設立。2003年5月中旬、ROから撤退。',
  },
  {
    period: '2004/4/1 ～ 2005/5/5',
    isHighlight: false,
    desc: '大学受験につき下位サイトも含め休止。丸々1年ですが、名目上の話なので、実質は半年程度かと思います。滑り込みにて第1志望校に合格。よかったよかった。',
  },
  {
    period: '〈第4期/inetd鯖〉2005/5/6 ～ 2008/3/?',
    isHighlight: true,
    meta: {
      siteName: "Don't Look Back（DLB）",
      handle: 'ゆうやみ',
      genres: '魔術士オーフェン・大藪春彦作品・バトルロワイアル・プロレス（→独立）他',
      sub: 'C2G・OBRN・21CPB（途中追加）',
    },
    desc: 'ゲーム系専門の「CRADLE 2 GRAVE」と、よろずサイトの「Don\'t Look Back」に分離して復活。受験中にWWEに目覚め、プロレス部門を追加。同年9月末に「21世紀パワーボム」（21CPB）として独立。2007年11月、「ORPHEN Remix」の運営を断念。',
  },
  {
    period: '〈第4期/さくら鯖〉2008/3/? ～ 2021/3',
    isHighlight: true,
    desc: '諸事情により急遽inetd鯖を解約することになり、さくら鯖に移転。1週間足らずで移転完了。',
  },
  {
    period: '〈第4期/GitHub Pages〉2021/3/21 ～ 2026/4/13',
    isHighlight: true,
    desc: 'さくらインターネットからGitHub Pagesへ移転。掲示板・CGI系は廃止。',
  },
  {
    period: '〈第4期/GitHub Pages〉2026/4/14 ～ 現在',
    isHighlight: true,
    desc: 'AIゴリ押しでフルリニューアル。',
  },
];
---

<Layout title="サイトの歴史" description="よろずサイト「Don't Look Back」の沿革。2000年の開設から現在まで。">
  <div class="container">
    <main>
      <h1 class="page-title">サイトの歴史</h1>

      <p class="lead">
        当サイトの歴史です。実は長い間やってまして、サイトタイトル変更に管理人名変更、取り扱いジャンル変更までしたので、一度振り返ってみたいなと思って作成しました。
      </p>

      <ol class="timeline">
        {historyEntries.map((entry) => (
          <li class={`timeline-item ${entry.isHighlight ? 'is-highlight' : 'is-pause'}`}>
            <div class="timeline-marker" aria-hidden="true" />
            <div class="timeline-body">
              <p class="timeline-period">{entry.period}</p>
              {entry.meta && (
                <dl class="meta-list">
                  <div class="meta-row">
                    <dt>サイト名</dt>
                    <dd>{entry.meta.siteName}</dd>
                  </div>
                  <div class="meta-row">
                    <dt>ハンドル</dt>
                    <dd>{entry.meta.handle}</dd>
                  </div>
                  <div class="meta-row">
                    <dt>取り扱いジャンル</dt>
                    <dd>{entry.meta.genres}</dd>
                  </div>
                  {entry.meta.sub && (
                    <div class="meta-row">
                      <dt>別管理/下位サイト</dt>
                      <dd>{entry.meta.sub}</dd>
                    </div>
                  )}
                </dl>
              )}
              <p class="timeline-desc">{entry.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </main>
  </div>
</Layout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 44px 24px;
  }

  @media (max-width: 600px) {
    .container {
      padding: 24px 16px;
    }
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 900;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--sky);
    color: var(--text);
  }

  .lead {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 40px;
    line-height: 1.8;
  }

  /* タイムライン */
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }

  /* 縦線 */
  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 10px;
    width: 2px;
    background: var(--sky-deep);
    opacity: 0.25;
  }

  .timeline-item {
    position: relative;
    padding-left: 40px;
    padding-bottom: 32px;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  /* ドットマーカー */
  .timeline-marker {
    position: absolute;
    left: 4px;
    top: 4px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--sky-deep);
    background: var(--white);
    box-sizing: border-box;
  }

  .is-highlight .timeline-marker {
    background: var(--sky-deep);
  }

  .is-pause .timeline-marker {
    opacity: 0.4;
  }

  .timeline-period {
    font-size: 0.82rem;
    font-weight: 800;
    color: var(--sky-deep);
    margin: 0 0 10px;
    line-height: 1.4;
  }

  .is-pause .timeline-period {
    color: var(--text-muted);
    font-weight: 600;
  }

  /* メタ情報 */
  .meta-list {
    background: var(--sky);
    border-radius: 6px;
    padding: 10px 14px;
    margin: 0 0 10px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2px 12px;
    font-size: 0.8rem;
    line-height: 1.7;
  }

  .meta-row {
    display: contents;
  }

  .meta-list dt {
    color: var(--sky-deep);
    font-weight: 700;
    white-space: nowrap;
  }

  .meta-list dd {
    margin: 0;
    color: var(--text);
    font-weight: 600;
  }

  .timeline-desc {
    font-size: 0.88rem;
    line-height: 1.8;
    margin: 0;
    color: var(--text);
  }

  .is-pause .timeline-desc {
    color: var(--text-muted);
  }
</style>
