---
// バトルロワイアル BR2生徒名簿ページ
import Layout from '@/layouts/Layout.astro';
import { br2Students } from '@/data/br-students';

const base = import.meta.env.BASE_URL;
---

<Layout title="生徒名簿（BR2）" description="映画「バトルロワイアル2」鹿之砦中学校3年B組42名の生徒名簿。">
  <div class="container">
    <nav class="breadcrumb" aria-label="パンくず">
      <a href={base}>HOME</a>
      <span aria-hidden="true">›</span>
      <a href={`${base}br/`}>バトルロワイアル</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">映画「BR2」生徒名簿</span>
    </nav>

    <main>
      <h1 class="page-title">映画「バトルロワイアル2」生徒名簿</h1>
      <p class="subtitle">町立鹿之砦中学校3年B組</p>

      <table class="roster-table">
        <thead>
          <tr>
            <th class="col-male">男子</th>
            <th class="col-num">番号</th>
            <th class="col-female">女子</th>
          </tr>
        </thead>
        <tbody>
          {br2Students.map((s, i) => (
            <tr>
              <td class={s.male ? 'male' : 'male male-empty'}>{s.male ?? '—'}</td>
              <td class="num">{i + 1}番</td>
              <td class="female">{s.female}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </main>
  </div>
</Layout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 44px 24px;
  }

  @media (max-width: 600px) {
    .container {
      padding: 24px 16px;
    }
  }

  .breadcrumb {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--mint-deep);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 900;
    margin-bottom: 8px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--mint);
    color: var(--text);
  }

  .subtitle {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 28px;
  }

  .roster-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  .roster-table thead tr {
    background: var(--mint);
  }

  .roster-table th {
    padding: 10px 14px;
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    border: 1px solid var(--border);
    color: var(--mint-deep);
  }

  .col-male,
  .col-female { width: 42%; }
  .col-num { width: 16%; }

  .roster-table td {
    padding: 9px 14px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  .roster-table tbody tr:nth-child(even) td {
    background: color-mix(in srgb, var(--mint) 15%, var(--white));
  }

  .num {
    text-align: center;
    background: color-mix(in srgb, var(--mint) 30%, var(--white)) !important;
    font-weight: 700;
    color: var(--mint-deep);
    font-size: 0.8rem;
  }

  .male {
    text-align: right;
    color: var(--text);
  }

  /* 男子なし行のセルはミュート表示 */
  .male-empty {
    color: var(--text-muted);
  }

  @media (max-width: 500px) {
    .roster-table td,
    .roster-table th {
      font-size: 0.78rem;
      padding: 7px 8px;
    }

    td.male,
    td.female {
      white-space: normal;
    }
  }
</style>
