---
// プロフィールページ
import Layout from '@/layouts/Layout.astro';

// プロフィール項目の定義（2014年6月時点の内容を保持）
const profileItems = [
  { label: 'ハンドル', value: 'ゆうやみ（旧：荒野の旅人→夕闇幻楼）' },
  { label: '性別', value: '男' },
  { label: '在住地', value: '大阪' },
  { label: '趣味', value: 'プロレス＆サッカー観戦、映画＆音楽鑑賞、読書、漫画、ゲーム、インターネット、ボウリング' },
] as const;
---

<Layout title="プロフィール" description="管理人ゆうやみのプロフィール。">
  <div class="container">
    <main>
      <h1 class="page-title">プロフィール</h1>

      <section class="section">
        <h2 class="section-title">管理人について</h2>
        <p class="note">※2014年6月時点の情報です。</p>

        <table class="profile-table">
          <tbody>
            <tr>
              <th>ハンドル</th>
              <td>
                ゆうやみ<br />
                <span class="note">（旧ハンドル：荒野の旅人→夕闇幻楼）</span>
              </td>
            </tr>
            <tr>
              <th>性別</th>
              <td>男</td>
            </tr>
            <tr>
              <th>在住地</th>
              <td>大阪</td>
            </tr>
            <tr>
              <th>趣味</th>
              <td>プロレス＆サッカー観戦、映画＆音楽鑑賞、読書、漫画、ゲーム、インターネット、ボウリング</td>
            </tr>
            <tr>
              <th>好きなライター</th>
              <td>
                <strong>一般：</strong><br />
                大藪春彦、高見広春、石田衣良、宮部みゆき、大沢在昌、筒井康隆、沢木耕太郎、山崎豊子、貴志祐介、塩野七生<br />
                <br />
                <strong>海外：</strong><br />
                金庸（中国の武侠小説家）、スティーブン・キング<br />
                <br />
                <strong>ライトノベル＆ゲームシナリオ系：</strong><br />
                秋田禎信、上遠野浩平、犬村小六、虚淵玄、田中ロミオ（山田一）、奈良原一鉄、るーすぼーい
              </td>
            </tr>
            <tr>
              <th>ボウリング</th>
              <td>
                2012年春より開始して週一で10Gほど練習してます。ハウスボール・ハウスシューズ・ノーリスタイの手ぶらスタイル。右利きのストローカーで使用ボールは11ポンド。<br />
                <br />
                月間アベレージ：140台前半 / 1G最高スコア：234
              </td>
            </tr>
            <tr>
              <th>連絡先</th>
              <td>
                X: <a href="https://twitter.com/u83unlimited" target="_blank" rel="noopener noreferrer">@u83unlimited</a><br />
                メール: <a href="mailto:u83ism@gmail.com">u83ism@gmail.com</a>
              </td>
            </tr>
          </tbody>
        </table>
      </section>
    </main>
  </div>
</Layout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 44px 24px;
  }

  @media (max-width: 600px) {
    .container {
      padding: 24px 16px;
    }
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 900;
    margin-bottom: 32px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--peach);
    color: var(--text);
  }

  .section {
    margin-bottom: 48px;
  }

  .section-title {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .note {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  /* プロフィールテーブル（データ用途のため<table>を維持） */
  .profile-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .profile-table th,
  .profile-table td {
    padding: 12px 16px;
    border: 1px solid var(--border);
    vertical-align: top;
    line-height: 1.7;
  }

  .profile-table th {
    background: var(--peach);
    color: var(--peach-deep);
    font-weight: 700;
    white-space: nowrap;
    width: 22%;
    text-align: right;
  }

  .profile-table td a {
    color: var(--peach-deep);
  }

  @media (max-width: 500px) {
    .profile-table th {
      width: auto;
      text-align: left;
      white-space: normal;
    }

    .profile-table th,
    .profile-table td {
      display: block;
      width: 100%;
    }

    .profile-table tr + tr th {
      border-top: 2px solid var(--border);
    }
  }
</style>
