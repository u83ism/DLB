---
// 魔虚楽踊 仮生徒名簿ページ
import Layout from '@/layouts/Layout.astro';
import { malesSelf, femalesSelf, malesTosho, femalesTosho } from '@/data/mkro-roster';

const base = import.meta.env.BASE_URL;
---

<Layout title="仮生徒名簿（魔虚楽踊）" description="魔虚楽踊 登場予定の仮生徒名簿。自作生徒79名・投稿生徒12名の計91名。">
  <div class="container">
    <nav class="breadcrumb" aria-label="パンくず">
      <a href={base}>HOME</a>
      <span aria-hidden="true">›</span>
      <a href={`${base}mkro/`}>魔虚楽踊</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">仮生徒名簿</span>
    </nav>

    <main>
      <h1 class="page-title">仮生徒名簿</h1>

      <p class="lead">以下、現在発表している生徒となります。<span class="tosho-note">水色背景の生徒は投稿された生徒です。</span></p>
      <p class="status">
        <strong>自作生徒：79名（男子39名/女子40名）発表<br>
        投稿生徒：12名（男子6名/女子6名）採用決定<br>
        【計91名決定】</strong>
      </p>

      <table class="roster">
        <thead>
          <tr>
            <th colspan="2">男子</th>
            <th colspan="2">女子</th>
          </tr>
        </thead>
        <tbody>
          {malesSelf.map((row, i) => (
            <tr>
              <td><a href={`${base}mkro/ndm/#${i * 2 + 1}`}>{row[0]}</a></td>
              <td>{row[1] ? <a href={`${base}mkro/ndm/#${i * 2 + 2}`}>{row[1]}</a> : ''}</td>
              <td><a href={`${base}mkro/ndf/#${i * 2 + 1}`}>{femalesSelf[i][0]}</a></td>
              <td><a href={`${base}mkro/ndf/#${i * 2 + 2}`}>{femalesSelf[i][1]}</a></td>
            </tr>
          ))}
          <tr>
            <td colspan="4"></td>
          </tr>
          <tr class="tosho-row">
            <td class="tosho"><a href={`${base}mkro/ndm/#t1`}>{malesTosho[0]}</a></td>
            <td class="tosho"><a href={`${base}mkro/ndm/#t2`}>{malesTosho[1]}</a></td>
            <td class="tosho"><a href={`${base}mkro/ndf/#t1`}>{femalesTosho[0]}</a></td>
            <td class="tosho"><a href={`${base}mkro/ndf/#t2`}>{femalesTosho[1]}</a></td>
          </tr>
          <tr class="tosho-row">
            <td class="tosho"><a href={`${base}mkro/ndm/#t4`}>{malesTosho[2]}</a></td>
            <td class="tosho"><a href={`${base}mkro/ndm/#t3`}>{malesTosho[3]}</a></td>
            <td class="tosho"><a href={`${base}mkro/ndf/#t3`}>{femalesTosho[2]}</a></td>
            <td class="tosho"><a href={`${base}mkro/ndf/#t4`}>{femalesTosho[3]}</a></td>
          </tr>
          <tr class="tosho-row">
            <td class="tosho"><a href={`${base}mkro/ndm/#t5`}>{malesTosho[4]}</a></td>
            <td class="tosho"><a href={`${base}mkro/ndm/#t6`}>{malesTosho[5]}</a></td>
            <td class="tosho"><a href={`${base}mkro/ndf/#t4`}>{femalesTosho[4]}</a></td>
            <td class="tosho"><a href={`${base}mkro/ndf/#t5`}>{femalesTosho[5]}</a></td>
          </tr>
        </tbody>
      </table>

      <nav class="back-nav">
        <a href={`${base}mkro/`} class="back-btn">← 魔虚楽踊 TOP</a>
        <a href={`${base}mkro/ndm/`} class="back-btn">男子詳細</a>
        <a href={`${base}mkro/ndf/`} class="back-btn">女子詳細</a>
      </nav>
    </main>
  </div>
</Layout>

<style>
  .container { max-width: 800px; margin: 0 auto; padding: 44px 24px; }
  @media (max-width: 600px) { .container { padding: 24px 16px; } }
  .breadcrumb { font-size: 0.78rem; color: var(--text-muted); margin-bottom: 24px; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .page-title { font-size: 1.6rem; font-weight: 900; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 3px solid var(--accent); color: var(--text); }
  .lead { font-size: 0.88rem; margin-bottom: 8px; }
  .tosho-note { font-weight: 700; color: #0066aa; }
  .status { font-size: 0.88rem; margin-bottom: 24px; padding: 12px 16px; background: var(--bg); border-radius: var(--radius); border: 1px solid var(--border); }
  .roster { width: 100%; border-collapse: collapse; font-size: 0.86rem; }
  .roster th { background: #ccffcc; font-weight: 700; padding: 8px 10px; border: 1px solid var(--border); text-align: center; }
  .roster td { padding: 8px 10px; border: 1px solid var(--border); width: 25%; }
  .roster a { color: var(--accent); text-decoration: none; }
  .roster a:hover { text-decoration: underline; }
  .tosho-row td.tosho { background: #ccffff; }
  .back-nav { display: flex; gap: 10px; margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border); flex-wrap: wrap; }
  .back-btn { display: inline-block; padding: 8px 16px; background: var(--white); border: 1px solid var(--accent); border-radius: var(--radius); font-size: 0.84rem; font-weight: 600; color: var(--accent); text-decoration: none; }
  .back-btn:hover { background: var(--bg); }
</style>
