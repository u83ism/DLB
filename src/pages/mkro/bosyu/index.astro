---
// 魔虚楽踊 生徒＆支給品募集ページ
import Layout from '@/layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

// 生徒募集ルール
const studentRules = [
  '採用する数は最大50人。',
  '投稿時に必要な項目は「投稿者のHN・投稿する生徒の名前・特徴」です。',
  '凄く長いですが設定関連は絶対読んでください。必須！設定絡みで問題があったりすると、ボツ率強烈にアップ、もしくはこちらで大修正をかける可能性があります。',
  '国籍は基本的に日本国籍です。ただし複数の国籍を持たせたり、海外在住等の設定は可能です。',
  '友人関係等は指定不可です。（クラス分けが未確定のため）もし書きたいなら、「クラスにおいて～」や「人付き合いは～」という風に曖昧に書いて下さい。',
  '設定絡みなど質問のある方は、気軽に掲示板に書き込み御願いします。ネタバレにならない範囲で答えさせていただきます。',
  'お一人様、投稿はいくらでも可能ですが、絞って作りこんだ方がよろしいかと思います。',
  '採用枠が全部埋まった時点で締め切ります。',
  '生徒案に関しては採用確定後、先行で投稿生徒名と投稿者名を併記してリストアップさせていただきます。さらに連載開始後、ネタバレ名簿の各生徒項目でも併記させていただきます。名前を公表されるのが嫌な方は投稿する際、その旨を書いて送って下さいませ。',
] as const;

// 支給品募集ルール
const supplyRules = [
  '採用する数は全部で50点分＋α。',
  '投稿時に必要な項目は「投稿者のHN・投稿する支給品の名前・特徴」です。',
  '凄く長いですが、設定関連は絶対読んでください。必須！設定絡みで問題があったりすると、ボツ率強烈にアップ、もしくはこちらで大修正をかける可能性があります。',
  'なお支給品として採用されなくても、他の所で登場できる可能性もあります。（＋αとはこのこと）その際も正式採用となり、投稿者名リストに上げさせていただきます。',
  '友人関係等は指定不可です。（クラス分けが未確定のため）もし書きたいなら、「クラスにおいて～」や「人付き合いは～」という風に曖昧に書いて下さい。',
  '設定絡みなど質問のある方は、気軽に掲示板に書き込み御願いします。ネタバレにならない範囲で答えさせていただきます。',
  'お一人様、投稿はいくらでも可能ですが、絞って作りこんだ方がよろしいかと思います。',
  'シナリオのネタバレを防ぐため、連載開始時に発表するのは投稿者とその方の採用品数のみになります。登場後は特殊用語辞典の方にでも、投稿支給品名、解説、投稿者名を併記させていただきます。名前を公表されるのが嫌な方は投稿する際、その旨を書いて送って下さいませ。',
] as const;
---

<Layout title="生徒＆支給品募集（魔虚楽踊）" description="魔虚楽踊 登場生徒および支給品の募集について。">
  <div class="container">
    <nav class="breadcrumb" aria-label="パンくず">
      <a href={base}>HOME</a>
      <span aria-hidden="true">›</span>
      <a href={`${base}mkro/`}>魔虚楽踊</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">生徒＆支給品募集</span>
    </nav>

    <main>
      <h1 class="page-title">生徒＆支給品募集について</h1>

      <section class="section">
        <h2 class="section-heading">生徒募集について</h2>
        <ul class="rule-list">
          {studentRules.map((r) => <li>{r}</li>)}
        </ul>
      </section>

      <section class="section">
        <h2 class="section-heading">支給品募集について</h2>
        <ul class="rule-list">
          {supplyRules.map((r) => <li>{r}</li>)}
        </ul>
      </section>

      <section class="section">
        <h2 class="section-heading">投稿について</h2>
        <p class="text">投稿は基本的にメールで御願いします。質問は掲示板もしくはメールで御願いします。<br>
          なお採用の可否についての質問は受付できませんので、よろしく御願いします。また発表をもって採用決定の報告とかえさせていただきます。</p>
      </section>

      <nav class="back-nav">
        <a href={`${base}mkro/`} class="back-btn">← 魔虚楽踊 TOP</a>
      </nav>
    </main>
  </div>
</Layout>

<style>
  .container { max-width: 800px; margin: 0 auto; padding: 44px 24px; }
  @media (max-width: 600px) { .container { padding: 24px 16px; } }
  .breadcrumb { font-size: 0.78rem; color: var(--text-muted); margin-bottom: 24px; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .page-title { font-size: 1.6rem; font-weight: 900; margin-bottom: 32px; padding-bottom: 12px; border-bottom: 3px solid var(--accent); color: var(--text); }
  .section { margin-bottom: 40px; }
  .section-heading { font-size: 1rem; font-weight: 800; color: var(--text); margin-bottom: 16px; padding: 8px 0 8px 16px; border-left: 4px solid var(--accent); }
  .rule-list { font-size: 0.88rem; line-height: 1.9; padding-left: 1.5em; }
  .rule-list li { margin-bottom: 0.6em; }
  .text { font-size: 0.88rem; line-height: 1.9; }
  .back-nav { margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border); }
  .back-btn { display: inline-block; padding: 8px 16px; background: var(--white); border: 1px solid var(--accent); border-radius: var(--radius); font-size: 0.84rem; font-weight: 600; color: var(--accent); text-decoration: none; }
  .back-btn:hover { background: var(--bg); }
</style>
